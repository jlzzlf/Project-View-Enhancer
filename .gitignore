# Unity package repository ignore rules
# Keep all .meta files tracked so GUIDs remain stable.

# Root-level documentation/package descriptor metas are safe to regenerate.
/README.md.meta
/CHANGELOG.md.meta
/package.json.meta

.vs/
.idea/
.vscode/
.consulo/

Library/
Temp/
Logs/
obj/
UserSettings/
MemoryCaptures/
Build/
Builds/
ExportedObj/
.gradle/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

*.pidb.meta
*.pdb.meta
*.mdb.meta

sysinfo.txt
Thumbs.db
.DS_Store
